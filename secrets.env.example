# Database Configuration
POSTGRES_PASSWORD=scheduler
POSTGRES_DB=scheduler
POSTGRES_USER=scheduler
# Docker Compose uses the db service host; switch to localhost for a local Postgres.
DATABASE_URL=postgresql+psycopg2://scheduler:scheduler@db:5432/scheduler
TEST_DATABASE_URL=postgresql+psycopg2://scheduler:scheduler@localhost:5432/scheduler_test_db

# Security & App Settings
SESSION_SECRET=your_super_secret_session_key
PROXY_PREFIX=
MULTI_AGENT_SETTINGS_PATH=../Multi-Agent-Platform/model_settings.json
# production / demo mode switch (production enables stricter defaults)
APP_ENV=production
# only allow requests with these Host headers (comma-separated)
SCHEDULER_TRUSTED_HOSTS=localhost,127.0.0.1,testserver
# trust proxy forwarding only from these hosts
SCHEDULER_PROXY_TRUSTED_HOSTS=127.0.0.1,::1,localhost
# force http -> https redirect in public environments
SCHEDULER_FORCE_HTTPS=true
# hardened session cookie settings
SCHEDULER_SESSION_HTTPS_ONLY=true
SCHEDULER_SESSION_SAME_SITE=lax
SCHEDULER_SESSION_COOKIE_NAME=session
SCHEDULER_SESSION_MAX_AGE_SECONDS=604800
# anonymous guest isolation cookie and retention policy
SCHEDULER_GUEST_COOKIE_NAME=guest_id
SCHEDULER_GUEST_COOKIE_MAX_AGE_SECONDS=259200
SCHEDULER_GUEST_DATA_TTL_HOURS=72
SCHEDULER_GUEST_CLEANUP_INTERVAL_SECONDS=300
# request guard settings for public demo
SCHEDULER_PROTECTED_API_PREFIXES=/api/,/model_settings
SCHEDULER_RATE_LIMIT_WINDOW_SECONDS=60
SCHEDULER_RATE_LIMIT_MAX_REQUESTS=120
SCHEDULER_REQUEST_TIMEOUT_SECONDS=30
SCHEDULER_MAX_REQUEST_BODY_BYTES=262144
# dangerous endpoints must stay disabled in public demo
SCHEDULER_ENABLE_DANGEROUS_EVAL_APIS=false
# MCP should be disabled publicly; if enabled, set a fixed token
SCHEDULER_ENABLE_MCP=false
SCHEDULER_MCP_AUTH_TOKEN=replace-with-long-random-token
# Monthly outbound LLM request cap (default 1000 when omitted)
SCHEDULER_MONTHLY_LLM_REQUEST_LIMIT=1000
# Max input length per user message (default 10000 when omitted)
SCHEDULER_MAX_INPUT_CHARS=10000
# Max output tokens per LLM response (default 5000 when omitted)
SCHEDULER_MAX_OUTPUT_TOKENS=5000

# LLM Provider API Keys & Base URLs
# Only uncomment and fill the ones you intend to use.

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

# Anthropic (Claude)
CLAUDE_API_KEY=sk-ant-...
# or ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_API_BASE=

# Google Gemini
GEMINI_API_KEY=AIza...
# or GOOGLE_API_KEY=AIza...
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai

# Groq
GROQ_API_KEY=gsk_...
GROQ_API_BASE=https://api.groq.com/openai/v1

# Prompt Guard (Groq gpt-oss-safeguard-20b) - always enabled
PROMPT_GUARD_MODEL=openai/gpt-oss-safeguard-20b
PROMPT_GUARD_BASE_URL=https://api.groq.com/openai/v1
# Optional: use a dedicated key if desired; defaults to GROQ_API_KEY.
# PROMPT_GUARD_API_KEY=gsk_...
